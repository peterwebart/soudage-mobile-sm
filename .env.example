# ──────────────────────────────────────────────────────────────
# Soudage Mobile SM — environment variables
# Copy to .env (local) and configure the same keys in Coolify.
# NEVER commit real secrets. .env is gitignored.
# ──────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, Open Graph, sitemap)
NEXT_PUBLIC_SITE_URL="https://soudagemobilesm.ca"

# ── Lead capture (quote form) ─────────────────────────────────
# Where quote requests are sent. All optional — if none are set,
# leads are still logged to the server console (visible in Coolify).

# Email delivery via Resend REST API (no SDK / dependency required).
# Create a key at https://resend.com → API Keys
RESEND_API_KEY=""
LEADS_EMAIL_TO="info@soudagemobilesm.ca"
LEADS_EMAIL_FROM="Soudage Mobile SM <noreply@soudagemobilesm.ca>"

# Automation webhook (Make / Zapier / n8n / Slack incoming webhook).
# The full lead payload is POSTed here as JSON.
LEADS_WEBHOOK_URL=""

# ── Payload CMS (PHASE 2 — see README "Activating the CMS") ────
# Provision PostgreSQL in Coolify, then set these to enable the
# admin panel at /admin and DB-backed lead storage.
DATABASE_URI=""
PAYLOAD_SECRET=""
